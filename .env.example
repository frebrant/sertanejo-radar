# Copie para .env e preencha com seus valores. NUNCA commitar o .env real.

# Bot do Telegram (obrigatório para receber notificações)
# 1) Crie um bot via @BotFather no Telegram → guarde o TOKEN
# 2) Inicie conversa com o bot (mande /start)
# 3) Pegue seu CHAT_ID via @userinfobot
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Gemini API (opcional — sem isso a copy é gerada por template estático fallback)
# Crie em https://aistudio.google.com/apikey  (grátis, 1.500 reqs/dia)
GEMINI_API_KEY=
